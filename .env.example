# Postgres credentials. Used by every app's DATABASE_URL and by the
# postgres service this compose defines.
POSTGRES_USER=cloud-template
POSTGRES_PASSWORD=cloud-template
POSTGRES_DB=cloud-template

# Session signing key — generate with: openssl rand -base64 48
APP_SECRET=change-me

# Internal token between filegate and the files app (only needed if
# you uncomment the files app in compose.yml).
FILEGATE_TOKEN=cloud-template-filegate
